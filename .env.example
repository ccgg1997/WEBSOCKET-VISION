YOLO_WS_HOST=0.0.0.0
YOLO_WS_PORT=8000
YOLO_WS_LOG_LEVEL=INFO
YOLO_WS_PUBLIC_BASE_URL=http://localhost:8000

# Auth
YOLO_WS_AUTH_USERNAME=camera-ingenio-01
YOLO_WS_AUTH_PASSWORD_HASH=
# Solo para pruebas locales. En produccion usa el hash.
YOLO_WS_AUTH_PASSWORD=

# Model
YOLO_WS_DEFAULT_MODEL_ID=default
YOLO_WS_MODEL_NAME=Modelo General
YOLO_WS_MODEL_PATH=runtime/model.pt
YOLO_WS_MODEL_URL=
YOLO_WS_MODEL_SHA256=
YOLO_WS_MODEL_DOWNLOAD_TIMEOUT=120
YOLO_WS_DEVICE=auto
YOLO_WS_TORCH_THREADS=2

# Multi-modelo opcional
# Si defines YOLO_WS_MODEL_IDS, el backend cargara todos esos modelos al iniciar.
# Usa ids ASCII simples para el protocolo, por ejemplo: default,cana
# YOLO_WS_MODEL_IDS=default,cana
# YOLO_WS_MODEL_DEFAULT_NAME=Modelo General
# YOLO_WS_MODEL_DEFAULT_PATH=runtime/model.pt
# YOLO_WS_MODEL_CANA_NAME=Modelo Cana
# YOLO_WS_MODEL_CANA_PATH=runtime/cana.pt
# Compatibilidad con vision-app, que manda "1" y "2" en model/model_id/model_selection.
# Si tus ids internos son default,cana, puedes fijarlo explicitamente asi:
# YOLO_WS_MODEL_SELECTION_ALIASES=1:default,2:cana

# Inference
YOLO_WS_CONF_THRESHOLD=0.35
YOLO_WS_IOU_THRESHOLD=0.45
YOLO_WS_IMGSZ=640
YOLO_WS_MAX_DET=100
YOLO_WS_MAX_FRAME_BYTES=4194304
YOLO_WS_JPEG_QUALITY=85
YOLO_WS_RETURN_IMAGE=false
YOLO_WS_AUTH_TIMEOUT_SECONDS=10

# Events
YOLO_WS_EVENTS_ENABLED=true
YOLO_WS_TRIGGER_LABELS=25
YOLO_WS_CLIP_SECONDS=5
YOLO_WS_EVENT_COOLDOWN_SECONDS=5
YOLO_WS_EVENT_RECORD_FPS=5
YOLO_WS_SNAPSHOT_INTERVAL_SECONDS=10
YOLO_WS_SNAPSHOT_SAVE_EMPTY=true

# Telegram opcional
YOLO_WS_TELEGRAM_ENABLED=false
YOLO_WS_TELEGRAM_BOT_TOKEN=
YOLO_WS_TELEGRAM_CHAT_ID=
YOLO_WS_TELEGRAM_MODEL_IDS=cana
YOLO_WS_TELEGRAM_FILL_THRESHOLD=50
YOLO_WS_TELEGRAM_TIMEOUT_SECONDS=10

# Database
# Por defecto apunta al contenedor postgres del docker-compose standalone.
# Cambialo solo si vas a usar una BD externa.
YOLO_WS_DATABASE_URL=postgresql://yolo_user:change-me-postgres@postgres:5432/yolo_events
YOLO_WS_DB_PATH=runtime/service.db
POSTGRES_DB=yolo_events
POSTGRES_USER=yolo_user
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_PORT=5432

# Object storage
# Por defecto apunta al contenedor MinIO del docker-compose standalone.
# Cambialo solo si vas a usar un endpoint externo.
YOLO_WS_STORAGE_BACKEND=minio
YOLO_WS_MINIO_ENDPOINT=minio:9000
YOLO_WS_MINIO_PUBLIC_ENDPOINT=http://localhost:9000
YOLO_WS_MINIO_ACCESS_KEY=minioadmin
YOLO_WS_MINIO_SECRET_KEY=change-me-minio
YOLO_WS_MINIO_BUCKET=yolo-events
YOLO_WS_MINIO_SECURE=false
YOLO_WS_MINIO_AUTO_CREATE_BUCKET=true
YOLO_WS_MINIO_PREFIX=events
YOLO_WS_PRESIGNED_URL_EXPIRY_SECONDS=3600
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Fallback local para pruebas
YOLO_WS_LOCAL_STORAGE_ROOT=runtime/object_storage
YOLO_WS_TEMP_DIR=runtime/tmp
