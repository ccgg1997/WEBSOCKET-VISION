YOLO_WS_HOST=0.0.0.0
YOLO_WS_PORT=8000
YOLO_WS_LOG_LEVEL=INFO

# Auth
YOLO_WS_AUTH_USERNAME=camera-ingenio-01
YOLO_WS_AUTH_PASSWORD_HASH=pbkdf2_sha256$390000$REPLACE_SALT_HEX$REPLACE_DIGEST_HEX

# Models
YOLO_WS_DEFAULT_MODEL_ID=default
YOLO_WS_MODELS_FILE=config/models.production.example.json
YOLO_WS_MODEL_DOWNLOAD_TIMEOUT=120
YOLO_WS_DEVICE=auto
YOLO_WS_TORCH_THREADS=2

# Compatibilidad
# Si no quieres usar archivo JSON, el backend aun soporta:
# YOLO_WS_MODEL_NAME=Modelo General
# YOLO_WS_MODEL_PATH=runtime/model.pt
# YOLO_WS_MODEL_URL=https://storage.example.com/models/yolo26n.pt
# YOLO_WS_MODEL_SHA256=
# YOLO_WS_MODEL_IDS=default,cana
# YOLO_WS_MODEL_DEFAULT_NAME=Modelo General
# YOLO_WS_MODEL_DEFAULT_URL=https://storage.example.com/models/yolo26n.pt
# YOLO_WS_MODEL_CANA_NAME=Modelo Cana
# YOLO_WS_MODEL_CANA_URL=https://storage.example.com/models/cana.pt
# YOLO_WS_MODEL_SELECTION_ALIASES=1:default,2:cana

# Inference
YOLO_WS_CONF_THRESHOLD=0.35
YOLO_WS_IOU_THRESHOLD=0.45
YOLO_WS_IMGSZ=640
YOLO_WS_MAX_DET=100
YOLO_WS_MAX_FRAME_BYTES=4194304
YOLO_WS_JPEG_QUALITY=85
YOLO_WS_RETURN_IMAGE=false
YOLO_WS_AUTH_TIMEOUT_SECONDS=10

# Event pipeline
YOLO_WS_EVENTS_ENABLED=true
YOLO_WS_TRIGGER_LABELS=25
YOLO_WS_CLIP_SECONDS=5
YOLO_WS_EVENT_COOLDOWN_SECONDS=5
YOLO_WS_EVENT_RECORD_FPS=5
YOLO_WS_SNAPSHOT_INTERVAL_SECONDS=10
YOLO_WS_SNAPSHOT_SAVE_EMPTY=true

# Telegram opcional
YOLO_WS_TELEGRAM_ENABLED=false
YOLO_WS_TELEGRAM_BOT_TOKEN=
YOLO_WS_TELEGRAM_CHAT_ID=
YOLO_WS_TELEGRAM_MODEL_IDS=cana
YOLO_WS_TELEGRAM_FILL_THRESHOLD=50
YOLO_WS_TELEGRAM_TIMEOUT_SECONDS=10
YOLO_WS_FILL_EVENT_STORAGE_PREFIX=cana

# PostgreSQL
YOLO_WS_DATABASE_URL=postgresql+psycopg://yolo_user:CHANGE_ME@postgres.internal:5432/yolo_events

# MinIO
YOLO_WS_STORAGE_BACKEND=minio
YOLO_WS_MINIO_ENDPOINT=minio.internal:9000
YOLO_WS_MINIO_ACCESS_KEY=CHANGE_ME
YOLO_WS_MINIO_SECRET_KEY=CHANGE_ME
YOLO_WS_MINIO_BUCKET=yolo-events
YOLO_WS_MINIO_SECURE=true
YOLO_WS_MINIO_AUTO_CREATE_BUCKET=true
YOLO_WS_MINIO_PREFIX=events
YOLO_WS_PRESIGNED_URL_EXPIRY_SECONDS=3600

# Temporary local workspace
YOLO_WS_TEMP_DIR=runtime/tmp
