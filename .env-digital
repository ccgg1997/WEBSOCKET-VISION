# DigitalOcean Droplet + docker compose
# Usa nombres de servicio del compose: postgres, minio, websocket-api

YOLO_WS_HOST=0.0.0.0
YOLO_WS_PORT=8000
YOLO_WS_LOG_LEVEL=INFO
YOLO_WS_PUBLIC_BASE_URL=http://YOUR-DROPLET-IP:8000

# Auth
YOLO_WS_AUTH_USERNAME=local-tester
# Si este archivo se usa directo con docker compose, escapa "$" como "$$"
YOLO_WS_AUTH_PASSWORD_HASH=pbkdf2_sha256$$390000$$REPLACE_SALT_HEX$$REPLACE_DIGEST_HEX

# Model
# Modelo versionado en el repo en runtime/model.pt
YOLO_WS_MODEL_PATH=runtime/model.pt
# YOLO_WS_MODEL_URL=
YOLO_WS_MODEL_SHA256=
YOLO_WS_MODEL_DOWNLOAD_TIMEOUT=120
YOLO_WS_DEVICE=auto
YOLO_WS_TORCH_THREADS=2

# Inference
YOLO_WS_CONF_THRESHOLD=0.35
YOLO_WS_IOU_THRESHOLD=0.45
YOLO_WS_IMGSZ=640
YOLO_WS_MAX_DET=100
YOLO_WS_MAX_FRAME_BYTES=4194304
YOLO_WS_JPEG_QUALITY=85
YOLO_WS_RETURN_IMAGE=false
YOLO_WS_AUTH_TIMEOUT_SECONDS=10

# Events
YOLO_WS_EVENTS_ENABLED=true
YOLO_WS_TRIGGER_LABELS=cell phone
YOLO_WS_CLIP_SECONDS=5
YOLO_WS_EVENT_COOLDOWN_SECONDS=5
YOLO_WS_EVENT_RECORD_FPS=5
YOLO_WS_SNAPSHOT_INTERVAL_SECONDS=10
YOLO_WS_SNAPSHOT_SAVE_EMPTY=true

# Database
YOLO_WS_DATABASE_URL=postgresql://yolo_user:CHANGE_ME_POSTGRES@postgres:5432/yolo_events
YOLO_WS_DB_PATH=runtime/service.db
POSTGRES_DB=yolo_events
POSTGRES_USER=yolo_user
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES
POSTGRES_PORT=5434

# Object storage
YOLO_WS_STORAGE_BACKEND=minio
YOLO_WS_MINIO_ENDPOINT=minio:9000
YOLO_WS_MINIO_PUBLIC_ENDPOINT=http://YOUR-DROPLET-IP:9010
YOLO_WS_MINIO_ACCESS_KEY=minioadmin
YOLO_WS_MINIO_SECRET_KEY=CHANGE_ME_MINIO
YOLO_WS_MINIO_BUCKET=yolo-events
YOLO_WS_MINIO_SECURE=false
YOLO_WS_MINIO_AUTO_CREATE_BUCKET=true
YOLO_WS_MINIO_PREFIX=events
YOLO_WS_PRESIGNED_URL_EXPIRY_SECONDS=3600
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO
MINIO_API_PORT=9010
MINIO_CONSOLE_PORT=9011

# Directorios escribibles dentro del contenedor para deploy
YOLO_WS_LOCAL_STORAGE_ROOT=/tmp/runtime/object_storage
YOLO_WS_TEMP_DIR=/tmp/runtime/tmp
